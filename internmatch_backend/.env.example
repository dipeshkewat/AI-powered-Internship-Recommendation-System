# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
PROJECT_NAME=InternMatch

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.mongodb.net/internmatch?retryWrites=true&w=majority
MONGODB_DB_NAME=internmatch

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=app/ml/artifacts/rf_model.joblib
ENCODER_PATH=app/ml/artifacts/encoders.joblib

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
